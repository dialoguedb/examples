# DialogueDB — get your key at https://dialoguedb.com
DIALOGUEDB_API_KEY=your-dialoguedb-api-key
DIALOGUEDB_ENDPOINT=https://backend.dialoguedb.com

# Anthropic — used by LangChain's ChatAnthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional: override the model (default: claude-sonnet-4-20250514)
# MODEL=claude-sonnet-4-20250514
